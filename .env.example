# Porta em que o servidor irá rodar
PORT=3000

# URL do webhook do n8n para envio de mensagens recebidas
N8N_WEBHOOK_URL=https://seu-n8n-webhook.example.com/webhook

# Habilita o envio de eventos para o n8n. Use false para desabilitar.
ENABLE_N8N=true

# Nível de log: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
